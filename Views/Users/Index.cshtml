@model Hotel.ViewModels.UserIndexViewModel

<div class="container">
    <h2 class="vv-page-title">Employee Management</h2>

    <div class="vv-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchString" value="@Model.SearchString" class="form-control" placeholder="Search by name or email..." style="width: 300px;" />
                <button type="submit" class="btn-vv-primary">Search</button>
            </form>
            <a asp-action="Create" class="btn-vv-outline">+ Register New Employee</a>
        </div>

        <table class="vv-table">
            <thead>
                <tr>
                    <th style="width: 25%;">Full Name</th>
                    <th style="width: 25%;">Email / Username</th>
                    <th style="width: 15%;">Status</th>
                    <th style="width: 20%;">Employment Dates</th>
                    <th style="width: 15%; text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr style="@(!user.IsActive ? "opacity: 0.6; background-color: #f9f9f9;" : "")">
                        <td style="font-weight: 600;">@user.FirstName @user.LastName</td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge-fired">Inactive</span>
                            }
                        </td>
                        <td style="font-size: 0.85rem;">
                            <div><strong>Hired:</strong> @user.AppointmentDate.ToString("MMM dd, yyyy")</div>
                            @if (user.DismissalDate.HasValue)
                            {
                                <div class="text-danger"><strong>Fired:</strong> @user.DismissalDate.Value.ToString("MMM dd, yyyy")</div>
                            }
                        </td>
                        <td style="text-align: right;">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn-vv-outline-sm">Edit</a>
                                @if (user.IsActive)
                                {
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Mark this employee as inactive?');">
                                        <button type="submit" class="btn-vv-danger-sm">Dismiss</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>