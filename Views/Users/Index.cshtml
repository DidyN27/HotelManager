@model Hotel.ViewModels.UserIndexViewModel

@if (Model.Pager != null && Model.Pager.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @* Previous *@
            <li class="page-item @(Model.Pager.CurrentPage > 1 ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-pg="@(Model.Pager.CurrentPage - 1)"
                   asp-route-searchString="@Model.SearchString">Previous</a>
            </li>

            @* Page Indicator *@
            <li class="page-item disabled">
                <span class="page-link">@Model.Pager.CurrentPage / @Model.Pager.TotalPages</span>
            </li>

            @* Next *@
            <li class="page-item @(Model.Pager.CurrentPage < Model.Pager.TotalPages ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-pg="@(Model.Pager.CurrentPage + 1)"
                   asp-route-searchString="@Model.SearchString">Next</a>
            </li>
        </ul>
    </nav>
}