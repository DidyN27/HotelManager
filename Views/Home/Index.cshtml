@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using Microsoft.AspNetCore.Identity
@using Hotel.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Velvet & Vine</title>

    <link rel="stylesheet" href="/css/site.css" asp-append-version="true">
    <link rel="stylesheet" href="/css/style.css" asp-append-version="true">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <nav class="navbar">
        <div class="logo-small">Velvet & Vine</div>
        <ul class="nav-links">
            <li><a asp-controller="Home" asp-action="Index">Home</a></li>

            @if (SignInManager.IsSignedIn(User))
            {
                <li class="dropdown">
                    <a href="#" class="dropbtn">Management ▾</a>
                    <ul class="dropdown-content">
                        @if (User.IsInRole("Admin"))
                        {
                            <li><a asp-controller="Users" asp-action="Index">Employees (Admin)</a></li>
                        }
                        <li><a asp-controller="Clients" asp-action="Index">Clients</a></li>
                        <li><a asp-controller="Rooms" asp-action="Index">Rooms</a></li>
                        <li><a asp-controller="Reservations" asp-action="Index">Reservations</a></li>
                    </ul>
                </li>
            }

            <li><a href="#hero">About Us</a></li>

            @if (SignInManager.IsSignedIn(User))
            {
                <li class="nav-item">
                    <form action="/Account/Logout" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-link-fancy"
                                style="background:none; border:none; color:white; cursor:pointer; font-weight:600; padding:0; margin:0;">
                            Logout (@User.Identity.Name)
                        </button>
                    </form>
                </li>
            }
            else
            {
                <li><a href="/Account/LogIn" class="btn-login">Login</a></li>
            }
        </ul>
    </nav>

    <header class="hero" id="hero">
        <div class="hero-content">
            <div class="main-logo">
                <h1>Velvet & Vine</h1>
                <p>Elegance in every reservation</p>
            </div>
            @if (!SignInManager.IsSignedIn(User))
            {
                <button class="scroll-btn" onclick="scrollToLogin()">Get Started</button>
            }
            else
            {
                @* FIXED: Use onclick to scroll to welcome instead of a hash if needed *@
                <button class="scroll-btn" onclick="document.getElementById('welcome-section').scrollIntoView({behavior: 'smooth'})">View Dashboard</button>
            }
        </div>
    </header>

    <section id="login-section" class="login-choice">
        <div id="welcome-section" class="py-5" style="text-align:center;">
            <h2 style="font-family: 'Playfair Display'; font-size: 3rem; color: #6b0d0d;">Welcome to Velvet & Vine</h2>
            @if (SignInManager.IsSignedIn(User))
            {
                <p>You are currently logged in as <strong>@User.Identity.Name</strong>.</p>
                <p>Use the <strong>Management</strong> menu above to navigate the system.</p>
            }
            else
            {
                <p>Please log in to the system to manage reservations, rooms, and clients.</p>
                <div class="mt-4">
                    @* FIXED: Pointed to your specific login path *@
                    <a href="/Account/LogIn" class="btn-vv-primary" style="padding: 15px 40px; text-decoration: none; border-radius: 30px; background: #6b0d0d; color: white; display: inline-block;">Access Staff Portal</a>
                </div>
            }
        </div>
    </section>

    <script>
        window.onscroll = function() {
            var nav = document.querySelector(".navbar");
            var hero = document.getElementById("hero");
            if (window.pageYOffset > 100) {
                nav.classList.add("nav-active");
                if(hero) hero.classList.add("hero-shrink");
            } else {
                nav.classList.remove("nav-active");
                if(hero) hero.classList.remove("hero-shrink");
            }
        };

        function scrollToLogin() {
            document.getElementById('login-section').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
</body>
</html>