<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velvet & Vine</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar nav-active">
            <div class="logo-small">Velvet & Vine</div>
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                
                <li class="dropdown">
                    <a href="#" class="dropbtn">Management ▾</a>
                    <ul class="dropdown-content">
                        @* Тук добавяме линковете към контролерите, които видяхме в проекта ти *@
                        <li><a asp-controller="User" asp-action="Index">Staff (Admin)</a></li>
                        <li><a asp-controller="Client" asp-action="Index">Clients</a></li>
                        <li><a asp-controller="Rooms" asp-action="Index">Rooms</a></li>
                        <li><a asp-controller="Reservations" asp-action="Index">Reservations</a></li>
                    </ul>
                </li>
                
                <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                
                @User.Identity?.Name
                {
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                            <button type="submit" class="btn-logout" style="background:none; border:none; color:white; cursor:pointer; font-family:inherit;">Log out (@User.Identity.Name)</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="LogIn" class="btn-login">Login</a></li>
                }
            </ul>
        </nav>
    </header>

    <div class="container" style="margin-top: 120px; min-height: 80vh;">
        <main role="main" class="pb-3">
            @* Тук ще се "инжектира" съдържанието на всички останали страници *@
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom">
        <div class="container">
            &copy; 2026 - Velvet & Vine - Elegance in every reservation
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
