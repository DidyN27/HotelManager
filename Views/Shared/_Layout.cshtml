@using Microsoft.AspNetCore.Identity
@using Hotel.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Velvet & Vine</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background-color: #f4e1d2;">
    @* Uses your --beige variable *@

    <header>
        @* This navbar now matches your Home/Index exactly *@
        <nav class="navbar nav-active">
            @* nav-active ensures it stays dark/bordo on subpages *@
            <div class="logo-small">Velvet & Vine</div>
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>

                @if (SignInManager.IsSignedIn(User))
                {
                    <li class="dropdown">
                        <a href="#" class="dropbtn">Management ▾</a>
                        <ul class="dropdown-content">
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a asp-controller="Users" asp-action="Index">Employees (Admin)</a></li>
                            }
                            <li><a asp-controller="Clients" asp-action="Index">Clients</a></li>
                            <li><a asp-controller="Rooms" asp-action="Index">Rooms</a></li>
                            <li><a asp-controller="Reservations" asp-action="Index">Reservations</a></li>
                        </ul>
                    </li>
                }

                @if (SignInManager.IsSignedIn(User))
                {
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                            <button type="submit" class="nav-link-btn" style="color:white; background:none; border:none; font-weight:600; cursor:pointer;">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <li><a asp-controller="Account" asp-action="LogIn" class="btn-login">Login</a></li>
                }
            </ul>
        </nav>
    </header>

    @* The padding-top: 120px is crucial because the navbar is "fixed" *@
    <div class="container" style="padding-top: 120px; padding-bottom: 50px;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted" style="background: white; border-top: 1px solid #ddd; padding: 20px 0;">
        <div class="container text-center">
            &copy; 2026 - Velvet & Vine Hotel - <a asp-area="" asp-controller="Home" asp-action="Privacy" style="color: #6b0d0d;">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>