@model Hotel.Models.Reservation

@{
    ViewData["Title"] = "Reservation Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="vv-page-title mb-0">Reservation #@Model.ReservationId</h1>
    <div>
        <a asp-action="Index" class="btn btn-vv-outline">Back to List</a>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="vv-card h-100">
            <h4 class="border-bottom pb-2 mb-3"><i class="fas fa-door-open"></i> Room Info</h4>
            <ul class="list-unstyled">
                <li class="mb-2"><strong>Room Number:</strong> <span class="float-end">@Model.ReservedRoom?.RoomNumber</span></li>
                <li class="mb-2"><strong>Type:</strong> <span class="float-end badge bg-info">@Model.ReservedRoom?.Type</span></li>
                <li class="mb-2"><strong>Capacity:</strong> <span class="float-end">@Model.ReservedRoom?.Capacity Persons</span></li>
            </ul>
            <div class="alert alert-secondary mt-3">
                <small>Room is currently marked as <strong>@(Model.ReservedRoom.IsFree ? "Free" : "Occupied")</strong></small>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="vv-card mb-4">
            <h4 class="border-bottom pb-2 mb-3"><i class="fas fa-calendar-alt"></i> Stay Details</h4>
            <div class="row text-center mb-3">
                <div class="col-6 border-end">
                    <p class="text-muted mb-0">Check-In</p>
                    <h5>@Model.CheckInDate.ToLongDateString()</h5>
                </div>
                <div class="col-6">
                    <p class="text-muted mb-0">Check-Out</p>
                    <h5>@Model.CheckOutDate.ToLongDateString()</h5>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-md-6">
                    <p>
                        <strong>Package:</strong>
                        @if (Model.IsAllInclusive)
                        {
                            <span class="badge bg-success">All Inclusive</span>
                        }
                        else if (Model.HasBreakfast)
                        {

                            <span class="badge bg-warning text-dark">Breakfast Included</span>
                        }
                        else
                        {

                            <span class="badge bg-secondary">Room Only</span>
                        }
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="h4">Total Price: <span class="text-primary">@Model.TotalAmount.ToString("C")</span></p>
                </div>
            </div>
        </div>

        <div class="vv-card">
            <h4 class="border-bottom pb-2 mb-3"><i class="fas fa-users"></i> Guests</h4>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in Model.Clients)
                    {
                        <tr>
                            <td>@client.FirstName @client.LastName</td>
                            <td>@client.Email</td>
                            <td>@client.PhoneNumber</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="mt-3">
                <small class="text-muted">Reserved by Staff: <strong>@Model.User?.UserName</strong></small>
            </div>
        </div>
    </div>
</div>