@model Hotel.ViewModels.ClientReservationsViewModel

<div class="container">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="vv-page-title">Reservations for @Model.ClientName</h2>
        <a asp-action="Index" class="btn-vv-outline" style="text-decoration:none; margin-top: 70px;">← Back to Clients</a>
    </div>

    <div class="vv-card">
        <table class="vv-table">
            <thead>
                <tr>
                    <th style="width: 15%;">Room</th>
                    <th style="width: 20%;">Check-In</th>
                    <th style="width: 20%;">Check-Out</th>
                    <th style="width: 15%;">Total Price</th>
                    <th style="width: 15%;">Status</th>
                    <th style="width: 15%; text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Reservations != null && Model.Reservations.Any())
                {
                    foreach (var res in Model.Reservations)
                    {
                        <tr>
                            <td style="font-weight: 600;">Room @res.RoomNumber</td>
                            <td>@res.CheckInDate.ToString("MMM dd, yyyy")</td>
                            <td>@res.CheckOutDate.ToString("MMM dd, yyyy")</td>
                            <td style="color: var(--bordo); font-weight: 600;">$@res.TotalAmount</td>
                            <td>
                                @if (res.CheckOutDate < DateTime.Now)
                                {
                                    <span class="badge-fired" style="background-color: #e9ecef; color: #495057;">Completed</span>
                                }
                                else
                                {
                                    <span class="badge-active">Upcoming</span>
                                }
                            </td>
                            <td style="text-align: right;">
                                <div class="btn-action-group">
                                    <a asp-controller="Reservations" asp-action="Details" asp-route-id="@res.Id" class="btn-edit-vv">Details</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <p style="color: #888;">No reservation history found for this client.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* --- Pagination Logic --- *@
    @if (Model.Pager != null && Model.Pager.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Pager.CurrentPage > 1 ? "" : "disabled")">
                    <a class="page-link" asp-action="Reservations" asp-route-id="@Model.ClientId" asp-route-pg="@(Model.Pager.CurrentPage - 1)">Previous</a>
                </li>

                @for (var pge = Model.Pager.StartPage; pge <= Model.Pager.EndPage; pge++)
                {
                    <li class="page-item @(pge == Model.Pager.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Reservations" asp-route-id="@Model.ClientId" asp-route-pg="@pge">@pge</a>
                    </li>
                }

                <li class="page-item @(Model.Pager.CurrentPage < Model.Pager.TotalPages ? "" : "disabled")">
                    <a class="page-link" asp-action="Reservations" asp-route-id="@Model.ClientId" asp-route-pg="@(Model.Pager.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>