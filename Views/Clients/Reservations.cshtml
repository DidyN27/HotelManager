@model Hotel.ViewModels.ClientReservationsViewModel

@if (Model.Pager != null && Model.Pager.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @* Previous Button *@
            <li class="page-item @(Model.Pager.CurrentPage > 1 ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Reservations"
                   asp-route-id="@Model.ClientId"
                   asp-route-pg="@(Model.Pager.CurrentPage - 1)">Previous</a>
            </li>

            @* Page Numbers *@
            @for (var pge = Model.Pager.StartPage; pge <= Model.Pager.EndPage; pge++)
            {
                <li class="page-item @(pge == Model.Pager.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Reservations"
                       asp-route-id="@Model.ClientId"
                       asp-route-pg="@pge">@pge</a>
                </li>
            }

            @* Next Button *@
            <li class="page-item @(Model.Pager.CurrentPage < Model.Pager.TotalPages ? "" : "disabled")">
                <a class="page-link"
                   asp-action="Reservations"
                   asp-route-id="@Model.ClientId"
                   asp-route-pg="@(Model.Pager.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-vv-outline">← Back to Clients</a>
</div>