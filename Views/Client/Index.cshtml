@model IEnumerable<Hotel.Models.Client>

<div class="management-card">
    <h2><i class="fas fa-users"></i> Registered Clients</h2>
    <a asp-action="Create" class="btn-login" style="width: auto; padding: 10px 20px;">+ Add New Client</a>
    
    <table class="table" style="width:100%; margin-top:20px; border-collapse: collapse;">
        <thead>
            <tr style="background: #6b1414; color: white;">
                <th style="padding: 12px;">Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model) {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 12px;">@client.FirstName @client.LastName</td>
                    <td>@client.Email</td>
                    <td>@client.PhoneNumber</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@client.ClientID">History</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>